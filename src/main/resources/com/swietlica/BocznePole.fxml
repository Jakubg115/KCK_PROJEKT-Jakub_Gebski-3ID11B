                  </ListView>
                  <Button fx:id="ustawienia" mnemonicParsing="false" onAction="#wejdzWUstawienia" text="Ustawienia">
                     <font>
                        <Font size="15.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Button>
                  <Button fx:id="wylogujSie" mnemonicParsing="false" onAction="#wylogowanie" text="Wyloguj się">
                     <font>
                        <Font size="15.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="30.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </content>
      </ScrollPane>
